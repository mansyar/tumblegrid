{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "include": ["src/**", "tests/**"],
    "ignore": ["node_modules", "dist", "coverage", "*.d.ts"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedImports": "error",
        "noUnusedVariables": "error",
        "noConstAssign": "error",
        "noPrecisionLoss": "error",
        "noUndeclaredVariables": "error",
        "noUnusedPrivateClassMembers": "error"
      },
      "style": {
        "noNonNullAssertion": "error",
        "useConst": "error",
        "useImportType": "error",
        "noUselessElse": "error",
        "noVar": "error"
      },
      "suspicious": {
        "noExplicitAny": "error",
        "noRedeclare": "error",
        "noShadowRestrictedNames": "error",
        "noDoubleEquals": "error",
        "noEmptyInterface": "error",
        "noThenProperty": "error"
      },
      "a11y": {
        "useAltText": "error",
        "useButtonType": "error",
        "noBlankTarget": "error"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always"
    }
  },
  "json": {
    "formatter": {
      "trailingCommas": "none"
    }
  }
}
