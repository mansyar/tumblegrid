{
  "name": "tumblegrid",
  "version": "0.1.0",
  "private": true,
  "description": "Isometric 3D marble physics puzzle game",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "biome lint ./src",
    "format": "biome format ./src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:browser": "vitest run --browser.enabled --browser.name=chromium"
  },
  "dependencies": {
    "@react-three/drei": "9.0.0",
    "@react-three/fiber": "8.9.2",
    "@react-three/rapier": "1.5.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "three": "0.170.0",
    "zustand": "5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "~1.9.4",
    "@playwright/test": "~1.48.2",
    "@types/node": "^25.9.2",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "~5.6.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
